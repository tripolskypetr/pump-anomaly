{
  "name": "pump-anomaly",
  "version": "0.1.0",
  "description": "Detector of synchronized trading pump signals via author-cluster deduplication, with path-aware exit replay and liquidation-cascade detection.",
  "keywords": [
    "trading",
    "pump",
    "pump-and-dump",
    "stop-hunting",
    "liquidation-cascade",
    "trading-signals",
    "trading-bot",
    "backtest",
    "anomaly-detection",
    "crypto",
    "cryptocurrency",
    "quant",
    "algotrading",
    "typescript"
  ],
  "type": "module",
  "license": "MIT",
  "main": "./build/index.cjs",
  "module": "./build/index.mjs",
  "types": "./types.d.ts",
  "exports": {
    ".": {
      "types": "./types.d.ts",
      "import": "./build/index.mjs",
      "require": "./build/index.cjs"
    }
  },
  "files": [
    "build",
    "types.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "12.3.0",
    "@types/node": "20.10.0",
    "@vitest/coverage-v8": "1.6.1",
    "rollup": "4.57.1",
    "rollup-plugin-dts": "6.3.0",
    "rollup-plugin-peer-deps-external": "2.2.4",
    "tslib": "2.8.1",
    "vitest": "1.6.1"
  }
}
